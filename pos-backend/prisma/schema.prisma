generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH (Better Auth manages sessions/accounts)
// ─────────────────────────────────────────

model User {
  id              String      @id @default(cuid())
  name            String
  email           String      @unique
  emailVerified   Boolean     @default(false)
  image           String?
  phone           String?
  role            Role        @default(CASHIER)
  restaurantId    String?
  mustChangePassword Boolean  @default(false)
  restaurant      Restaurant? @relation("RestaurantStaff", fields: [restaurantId], references: [id])
  ownedRestaurant Restaurant? @relation("RestaurantOwner")

  // Better Auth tables
  sessions Session[]
  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([userId])
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────
// RESTAURANT (TENANT)
// ─────────────────────────────────────────

model Restaurant {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique // URL-safe name: "pizza-palace"
  address     String
  city        String
  phone       String
  email       String
  logo        String?
  description String?
  currency    String           @default("INR")
  status      RestaurantStatus @default(PENDING)

  // Owner (1-to-1)
  ownerId String @unique
  owner   User   @relation("RestaurantOwner", fields: [ownerId], references: [id])

  // Staff (1-to-many)
  staff User[] @relation("RestaurantStaff")

  // Restaurant data (fully isolated)
  tables         Table[]
  diningAreas    DiningArea[]
  menuItems      MenuItem[]
  menuCategories MenuCategory[]
  orders         Order[]
  payments       Payment[]
  auditLogs      AuditLog[]
  qrCodes        QrCode[]

  // Inventory
  inventoryItems  InventoryItem[]
  inventoryAlerts InventoryAlert[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  stockCounts     StockCount[]

  // Rejection reason from super admin
  rejectionReason String?

  // Subscription plan
  plan Plan @default(STARTER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
}

// ─────────────────────────────────────────
// MENU
// ─────────────────────────────────────────

model MenuCategory {
  id           String     @id @default(cuid())
  name         String // "Starters", "Main Course", "Drinks"
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItem {
  id             String            @id @default(cuid())
  name           String
  description    String?
  price          Float
  image          String?
  available      Boolean           @default(true)
  isVeg          Boolean           @default(true)
  restaurantId   String
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId     String
  category       MenuCategory      @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  variants       MenuItemVariant[]
  inventoryItems InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
}

model MenuItemVariant {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  label      String
  price      Float
  available  Boolean  @default(true)
  sortOrder  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuItemId])
}

// ─────────────────────────────────────────
// TABLES
// ─────────────────────────────────────────

model DiningArea {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  code         String
  floor        String?
  climate      AreaClimate      @default(AC)
  experience   DiningExperience @default(STANDARD)
  color        String           @default("#F6B100")
  sortOrder    Int              @default(0)
  isActive     Boolean          @default(true)
  tables       Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
}

model Table {
  id               String       @id @default(cuid())
  tableNo          Int
  label            String?
  minSeats         Int          @default(1)
  seats            Int
  shape            TableShape   @default(SQUARE)
  isCombinable     Boolean      @default(false)
  combinationGroup String?
  isActive         Boolean      @default(true)
  status           TableStatus  @default(AVAILABLE)
  restaurantId     String
  restaurant       Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  areaId           String?
  area             DiningArea?  @relation(fields: [areaId], references: [id], onDelete: SetNull)
  currentOrderId   String?
  currentOrder     Order?       @relation("ActiveTableOrder", fields: [currentOrderId], references: [id])
  orders           Order[]      @relation("TableOrders")
  orderAssignments OrderTable[] @relation("TableOrderAssignments")
  qrCodes          QrCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, tableNo])
  @@unique([restaurantId, label])
  @@index([restaurantId])
  @@index([restaurantId, areaId, status])
  @@index([restaurantId, combinationGroup])
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────

model Order {
  id               String       @id @default(cuid())
  orderNo          Int // Auto-incrementing display number per restaurant
  orderType        OrderType    @default(DINE_IN)
  restaurantId     String
  restaurant       Restaurant   @relation(fields: [restaurantId], references: [id])
  tableId          String?
  table            Table?       @relation("TableOrders", fields: [tableId], references: [id])
  activeOnTables   Table[]      @relation("ActiveTableOrder")
  tableAssignments OrderTable[] @relation("OrderTableAssignments")

  // Customer info
  customerName  String
  customerPhone String
  guests        Int

  // Order status lifecycle
  orderStatus OrderStatus @default(PENDING)

  // Kitchen tracking
  kitchenNote       String?
  kitchenAcceptedAt DateTime?
  kitchenReadyAt    DateTime?

  // Billing
  subtotal     Float
  taxRate      Float @default(5)
  tax          Float
  totalWithTax Float

  // Payment
  paymentStatus     PaymentStatus @default(UNPAID)
  paymentMethod     String?
  razorpayOrderId   String?
  razorpayPaymentId String?

  items   OrderItem[]
  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, orderNo])
  @@index([restaurantId])
  @@index([tableId])
  @@index([orderStatus])
  @@index([restaurantId, createdAt])
}

model OrderTable {
  orderId String
  order   Order  @relation("OrderTableAssignments", fields: [orderId], references: [id], onDelete: Cascade)
  tableId String
  table   Table  @relation("TableOrderAssignments", fields: [tableId], references: [id])

  assignedAt DateTime @default(now())

  @@id([orderId, tableId])
  @@index([tableId])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  name         String // Snapshot of name at time of order
  price        Float // Snapshot of price at time of order
  quantity     Int
  note         String? // Special instructions per item
  variantId    String? // Null if no variant selected
  variantLabel String? // Snapshot of variant label (e.g., "30ml")

  @@index([orderId])
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id           String     @id @default(cuid())
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id])
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  paymentId    String     @unique // Razorpay payment_id
  amount       Float
  currency     String     @default("INR")
  status       String
  method       String?
  email        String?
  contact      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([orderId])
}

// ─────────────────────────────────────────
// AUDIT LOG (Security)
// ─────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  userId       String
  action       String // "ORDER_CREATED", "MENU_UPDATED", "STAFF_INVITED"
  resource     String // "Order", "MenuItem", "User"
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  KITCHEN
  CASHIER
  WAITER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum RestaurantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  OUT_OF_SERVICE
}

enum AreaClimate {
  AC
  NON_AC
  OUTDOOR
}

enum DiningExperience {
  STANDARD
  VIP
  PRIVATE
  BAR
}

enum TableShape {
  SQUARE
  ROUND
  RECTANGLE
  BOOTH
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum InventoryLogType {
  RESTOCK
  SALE
  ADJUSTMENT
  WASTE
  STOCK_COUNT
  PO_RECEIVE
}

enum InventoryAlertLevel {
  WARNING
  CRITICAL
  EXPIRY
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  DELIVERED
  CANCELLED
}

enum StockCountStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────

model Supplier {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  contactName  String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  leadTimeDays Int        @default(1)

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
}

model InventoryItem {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  unit           String
  currentStock   Float
  totalStock     Float
  alertThreshold Float      @default(30)
  alertEnabled   Boolean    @default(true)

  // Menu link
  menuItemId   String?
  menuItem     MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  variantLabel String?

  // Costing & sourcing
  costPerUnit Float?
  supplier    String? // legacy plain-text kept for backward compat
  supplierId  String?
  supplierRef Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // New operational fields
  expiryDate      DateTime? // batch expiry date
  reorderPoint    Float? // alert when currentStock falls below this
  reorderQuantity Float? // suggested PO quantity
  location        String? // "Walk-in Fridge", "Dry Storage", "Bar"

  lastRestockedAt DateTime?

  logs               InventoryLog[]
  alerts             InventoryAlert[]
  purchaseOrderItems PurchaseOrderItem[]
  stockCountItems    StockCountItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([supplierId])
}

model InventoryLog {
  id              String           @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            InventoryLogType
  quantity        Float
  stockAfter      Float
  note            String?
  orderId         String?
  createdAt       DateTime         @default(now())

  @@index([inventoryItemId])
  @@index([createdAt])
}

model InventoryAlert {
  id              String              @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  restaurantId    String
  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  message         String
  level           InventoryAlertLevel
  isRead          Boolean             @default(false)
  createdAt       DateTime            @default(now())

  @@index([restaurantId])
  @@index([isRead])
  @@index([createdAt])
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplierId       String?
  supplier         Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status           PurchaseOrderStatus @default(DRAFT)
  expectedDelivery DateTime?
  deliveredAt      DateTime?
  notes            String?
  totalCost        Float               @default(0)

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id               String         @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId  String?
  inventoryItem    InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName         String
  quantity         Float
  unit             String
  costPerUnit      Float          @default(0)
  receivedQuantity Float          @default(0)

  createdAt DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model StockCount {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       StockCountStatus @default(IN_PROGRESS)
  notes        String?
  completedAt  DateTime?

  items StockCountItem[]

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([status])
}

model StockCountItem {
  id              String        @id @default(cuid())
  stockCountId    String
  stockCount      StockCount    @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  expectedStock   Float
  actualStock     Float?
  variance        Float?
  note            String?

  @@index([stockCountId])
  @@index([inventoryItemId])
}

// ─────────────────────────────────────────
// QR MENU
// ─────────────────────────────────────────

model QrCode {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label        String
  tableId      String?
  table        Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  slug         String     @unique
  enabled      Boolean    @default(true)
  scanCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([slug])
}
