generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH (Better Auth manages sessions/accounts)
// ─────────────────────────────────────────

model User {
  id                 String      @id @default(cuid())
  name               String
  email              String      @unique
  emailVerified      Boolean     @default(false)
  image              String?
  phone              String?
  role               Role        @default(CASHIER)
  restaurantId       String?
  mustChangePassword Boolean     @default(false)
  restaurant         Restaurant? @relation("RestaurantStaff", fields: [restaurantId], references: [id])
  ownedRestaurant    Restaurant? @relation("RestaurantOwner")

  // Referral relations
  referralsMade    Referral[] @relation("ReferralsMade")
  referralReceived Referral?  @relation("ReferralReceived")

  // Better Auth tables
  sessions Session[]
  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([userId])
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────
// RESTAURANT (TENANT)
// ─────────────────────────────────────────

model Restaurant {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique // URL-safe name: "pizza-palace"
  address     String
  city        String
  phone       String
  email       String
  logo        String?
  description String?
  currency    String           @default("INR")
  timezone    String           @default("Asia/Kolkata")
  gstin       String?          // 15-char GST Identification Number for GSTR filing
  stateCode   String?          // 2-digit state code e.g. "27" = Maharashtra
  status      RestaurantStatus @default(PENDING)

  // Owner (1-to-1)
  ownerId String @unique
  owner   User   @relation("RestaurantOwner", fields: [ownerId], references: [id])

  // Staff (1-to-many)
  staff User[] @relation("RestaurantStaff")

  // Restaurant data (fully isolated)
  tables         Table[]
  diningAreas    DiningArea[]
  menuItems      MenuItem[]
  menuCategories MenuCategory[]
  orders         Order[]
  payments       Payment[]
  auditLogs      AuditLog[]
  qrCodes        QrCode[]
  taxGroups      TaxGroup[]

  // Inventory
  inventoryItems  InventoryItem[]
  inventoryAlerts InventoryAlert[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  stockCounts     StockCount[]
  reservations    Reservation[]

  // Rejection reason from super admin
  rejectionReason String?

  // Subscription plan
  plan Plan @default(STARTER)

  // Referral system
  referralCode String? @unique // e.g. "spice-garden-a3f2" — generated on APPROVAL
  referredById String? // User.id of the owner who referred this restaurant
  creditDays   Int     @default(0) // accumulated free-day credits from referrals

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([referralCode])
}

// ─────────────────────────────────────────
// TAX GROUPS
// ─────────────────────────────────────────

/// Reusable tax profile assigned to menu items.
/// Mirrors Petpooja / Posist "Tax Group" concept.
model TaxGroup {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name      String   // "GST 5%", "GST 18%", "Alcohol VAT", "MRP Incl. 18%", "Exempt"
  type      TaxType  // GST | VAT | INCLUDED | EXEMPT

  // GST fields (type = GST or INCLUDED)
  cgst      Float    @default(0)  // Central GST %  (e.g. 2.5 for 5% slab)
  sgst      Float    @default(0)  // State GST %    (e.g. 2.5 for 5% slab)
  igst      Float    @default(0)  // Inter-state GST % (usually cgst+sgst)

  // VAT fields (type = VAT — alcohol, state excise etc.)
  vatRate   Float    @default(0)  // e.g. 25 for 25% state VAT
  stateName String?              // e.g. "Maharashtra" — for audit trail

  // Metadata
  hsnSacCode String?  // HSN for goods / SAC for services
  isDefault  Boolean  @default(false) // one default per restaurant
  isSystem   Boolean  @default(false) // seeded automatically, label-only editable

  menuItems  MenuItem[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

// ─────────────────────────────────────────
// MENU
// ─────────────────────────────────────────

model MenuCategory {
  id           String     @id @default(cuid())
  name         String // "Starters", "Main Course", "Drinks"
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItem {
  id             String            @id @default(cuid())
  name           String
  description    String?
  price          Float
  image          String?
  available      Boolean           @default(true)
  isVeg          Boolean           @default(true)
  restaurantId   String
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId     String
  category       MenuCategory      @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  variants       MenuItemVariant[]
  inventoryItems InventoryItem[]

  // Tax assignment
  taxGroupId String?
  taxGroup   TaxGroup? @relation(fields: [taxGroupId], references: [id], onDelete: SetNull)

  // MRP / packaged goods
  isMrpItem  Boolean @default(false) // true = price is MRP (tax already included)
  mrp        Float?                  // actual MRP printed on label

  // GST compliance codes
  hsnCode    String?  // HSN code for goods (packaged items)
  sacCode    String?  // SAC code for services (restaurant food = 996331)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
  @@index([taxGroupId])
}

model MenuItemVariant {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  label      String
  price      Float
  available  Boolean  @default(true)
  sortOrder  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuItemId])
}

// ─────────────────────────────────────────
// TABLES
// ─────────────────────────────────────────

model DiningArea {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  code         String
  floor        String?
  climate      AreaClimate      @default(AC)
  experience   DiningExperience @default(STANDARD)
  color        String           @default("#F6B100")
  sortOrder    Int              @default(0)
  isActive     Boolean          @default(true)
  tables       Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
}

model Table {
  id               String        @id @default(cuid())
  tableNo          Int
  label            String?
  minSeats         Int           @default(1)
  seats            Int
  shape            TableShape    @default(SQUARE)
  isCombinable     Boolean       @default(false)
  combinationGroup String?
  isActive         Boolean       @default(true)
  status           TableStatus   @default(AVAILABLE)
  restaurantId     String
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  areaId           String?
  area             DiningArea?   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  currentOrderId   String?
  currentOrder     Order?        @relation("ActiveTableOrder", fields: [currentOrderId], references: [id])
  orders           Order[]       @relation("TableOrders")
  orderAssignments OrderTable[]  @relation("TableOrderAssignments")
  qrCodes          QrCode[]
  reservations     Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, tableNo])
  @@unique([restaurantId, label])
  @@index([restaurantId])
  @@index([restaurantId, areaId, status])
  @@index([restaurantId, combinationGroup])
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────

model Order {
  id               String       @id @default(cuid())
  orderNo          Int // Auto-incrementing display number per restaurant
  orderType        OrderType    @default(DINE_IN)
  restaurantId     String
  restaurant       Restaurant   @relation(fields: [restaurantId], references: [id])
  tableId          String?
  table            Table?       @relation("TableOrders", fields: [tableId], references: [id])
  activeOnTables   Table[]      @relation("ActiveTableOrder")
  tableAssignments OrderTable[] @relation("OrderTableAssignments")

  // Customer info
  customerName  String
  customerPhone String
  guests        Int

  // Order status lifecycle
  orderStatus OrderStatus @default(PENDING)

  // Kitchen tracking
  kitchenNote       String?
  kitchenAcceptedAt DateTime?
  kitchenReadyAt    DateTime?

  // Billing — per-tax-type breakdown
  subtotal     Float
  cgstTotal    Float         @default(0) // CGST collected across all GST items
  sgstTotal    Float         @default(0) // SGST collected across all GST items
  igstTotal    Float         @default(0) // IGST (inter-state, rare for restaurants)
  vatTotal     Float         @default(0) // State VAT on alcohol / non-GST items
  taxTotal     Float         @default(0) // cgstTotal + sgstTotal + igstTotal + vatTotal

  // Discount (applied before tax — correct per GST law)
  discountType  String?      // "FLAT" | "PERCENT"
  discountValue Float?       // the input value (₹ or %)
  discountAmt   Float        @default(0) // computed discount in ₹

  totalWithTax Float

  // Legacy fields — kept for backward compat with old orders, not used for new orders
  taxRate      Float?  // deprecated: was a single flat rate
  tax          Float?  // deprecated: was a single tax amount

  // Payment
  paymentStatus     PaymentStatus @default(UNPAID)
  paymentMethod     String?
  razorpayOrderId   String?
  razorpayPaymentId String?

  items   OrderItem[]
  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, orderNo])
  @@index([restaurantId])
  @@index([tableId])
  @@index([orderStatus])
  @@index([restaurantId, createdAt])
}

model OrderTable {
  orderId String
  order   Order  @relation("OrderTableAssignments", fields: [orderId], references: [id], onDelete: Cascade)
  tableId String
  table   Table  @relation("TableOrderAssignments", fields: [tableId], references: [id])

  assignedAt DateTime @default(now())

  @@id([orderId, tableId])
  @@index([tableId])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  name         String // Snapshot of name at time of order
  price        Float  // Snapshot of price at time of order (MRP for MRP items)
  quantity     Int
  note         String? // Special instructions per item
  variantId    String? // Null if no variant selected
  variantLabel String? // Snapshot of variant label (e.g., "30ml")

  // Tax snapshot — frozen at order-creation time so receipts are always accurate
  taxGroupName String?  // e.g. "GST 5%"
  taxType      String?  // "GST" | "VAT" | "INCLUDED" | "EXEMPT"
  cgstRate     Float    @default(0)
  sgstRate     Float    @default(0)
  igstRate     Float    @default(0)
  vatRate      Float    @default(0)
  cgstAmt      Float    @default(0)
  sgstAmt      Float    @default(0)
  igstAmt      Float    @default(0)
  vatAmt       Float    @default(0)
  taxAmt       Float    @default(0) // total tax on this line
  isMrpItem    Boolean  @default(false)
  hsnCode      String?
  sacCode      String?

  @@index([orderId])
}

model Reservation {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String
  table        Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  reservedAt   DateTime
  partySize    Int
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId, reservedAt])
  @@index([tableId, reservedAt])
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id           String     @id @default(cuid())
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id])
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  paymentId    String     @unique // Razorpay payment_id
  amount       Float
  currency     String     @default("INR")
  status       String
  method       String?
  email        String?
  contact      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([orderId])
}

// ─────────────────────────────────────────
// AUDIT LOG (Security)
// ─────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  userId       String
  action       String // "ORDER_CREATED", "MENU_UPDATED", "STAFF_INVITED"
  resource     String // "Order", "MenuItem", "User"
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  KITCHEN
  CASHIER
  WAITER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TaxType {
  GST      // CGST + SGST applied on top of price
  VAT      // State VAT / Excise (alcohol — not GST)
  INCLUDED // MRP item — tax already baked into the price, back-calculated
  EXEMPT   // No tax (e.g. plain water below 20L, exempted items)
}

enum RestaurantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// ─────────────────────────────────────────
// REFERRAL SYSTEM
// ─────────────────────────────────────────

enum ReferralStatus {
  PENDING    // new restaurant registered, not yet approved
  COMPLETED  // restaurant approved, reward given to both sides
  EXPIRED    // not approved within 90 days — no reward
}

model Referral {
  id         String         @id @default(cuid())
  // The owner who shared their referral link
  referrerId String
  referrer   User           @relation("ReferralsMade", fields: [referrerId], references: [id])
  // The new restaurant owner who used the link
  refereeId  String         @unique // One referral record per new owner
  referee    User           @relation("ReferralReceived", fields: [refereeId], references: [id])

  status     ReferralStatus @default(PENDING)

  // Both-side rewards (configurable per referral if needed later)
  referrerRewardDays Int     @default(30) // days credited to referrer on completion
  refereeRewardDays  Int     @default(15) // days credited to new restaurant on completion

  rewardGiven Boolean   @default(false)
  expiresAt   DateTime  // 90 days from createdAt — after this → EXPIRED
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([referrerId])
  @@index([status])
  @@index([expiresAt])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  OUT_OF_SERVICE
}

enum AreaClimate {
  AC
  NON_AC
  OUTDOOR
}

enum DiningExperience {
  STANDARD
  VIP
  PRIVATE
  BAR
}

enum TableShape {
  SQUARE
  ROUND
  RECTANGLE
  BOOTH
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum InventoryLogType {
  RESTOCK
  SALE
  ADJUSTMENT
  WASTE
  STOCK_COUNT
  PO_RECEIVE
}

enum InventoryAlertLevel {
  WARNING
  CRITICAL
  EXPIRY
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  DELIVERED
  CANCELLED
}

enum StockCountStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────

model Supplier {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  contactName  String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  leadTimeDays Int        @default(1)

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
}

model InventoryItem {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  unit           String
  currentStock   Float
  totalStock     Float
  alertThreshold Float      @default(30)
  alertEnabled   Boolean    @default(true)

  // Menu link
  menuItemId   String?
  menuItem     MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  variantLabel String?

  // Costing & sourcing
  costPerUnit Float?
  supplier    String? // legacy plain-text kept for backward compat
  supplierId  String?
  supplierRef Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // New operational fields
  expiryDate      DateTime? // batch expiry date
  reorderPoint    Float? // alert when currentStock falls below this
  reorderQuantity Float? // suggested PO quantity
  location        String? // "Walk-in Fridge", "Dry Storage", "Bar"

  lastRestockedAt DateTime?

  logs               InventoryLog[]
  alerts             InventoryAlert[]
  purchaseOrderItems PurchaseOrderItem[]
  stockCountItems    StockCountItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([supplierId])
}

model InventoryLog {
  id              String           @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            InventoryLogType
  quantity        Float
  stockAfter      Float
  note            String?
  orderId         String?
  createdAt       DateTime         @default(now())

  @@index([inventoryItemId])
  @@index([createdAt])
}

model InventoryAlert {
  id              String              @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  restaurantId    String
  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  message         String
  level           InventoryAlertLevel
  isRead          Boolean             @default(false)
  createdAt       DateTime            @default(now())

  @@index([restaurantId])
  @@index([isRead])
  @@index([createdAt])
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplierId       String?
  supplier         Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status           PurchaseOrderStatus @default(DRAFT)
  expectedDelivery DateTime?
  deliveredAt      DateTime?
  notes            String?
  totalCost        Float               @default(0)

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id               String         @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId  String?
  inventoryItem    InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName         String
  quantity         Float
  unit             String
  costPerUnit      Float          @default(0)
  receivedQuantity Float          @default(0)

  createdAt DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model StockCount {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       StockCountStatus @default(IN_PROGRESS)
  notes        String?
  completedAt  DateTime?

  items StockCountItem[]

  createdAt DateTime @default(now())

  @@index([restaurantId])
  @@index([status])
}

model StockCountItem {
  id              String        @id @default(cuid())
  stockCountId    String
  stockCount      StockCount    @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  expectedStock   Float
  actualStock     Float?
  variance        Float?
  note            String?

  @@index([stockCountId])
  @@index([inventoryItemId])
}

// ─────────────────────────────────────────
// QR MENU
// ─────────────────────────────────────────

model QrCode {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label        String
  tableId      String?
  table        Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  slug         String     @unique
  enabled      Boolean    @default(true)
  scanCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([slug])
}
